<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>    
    <add key="server_url" value="http://localhost:9000" />
  </appSettings>
  <connectionStrings>
    <clear />
    <!-- SQL Server: providerName="Microsoft.Data.SqlClient" connectionString="Data Source=localhost;Initial Catalog=finance;User ID=sa;Password=123456" -->
    <!-- SQLite:     providerName="Microsoft.Data.Sqlite"    connectionString="Data Source=finance.db" -->
    <add name="default" connectionString="Data Source=localhost;Initial Catalog=finance;User ID=sa;Password=123456" providerName="Microsoft.Data.SqlClient" />
  </connectionStrings>
</configuration>
